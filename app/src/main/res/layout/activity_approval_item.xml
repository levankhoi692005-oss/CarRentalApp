<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/xemchitiet"
    android:layout_margin="8dp"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/vienmauden">

    <!-- ===================== HEADER ===================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- ANH XE -->

        <ImageView
            android:id="@+id/imgXe"
            android:layout_width="115dp"
            android:layout_height="95dp"
            android:scaleType="centerCrop"
            android:src="@drawable/car"
            />

        <!-- THONG TIN -->

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- TEN XE -->

            <TextView
                android:id="@+id/txtmadon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã đơn: S450"
                android:textColor="#111111"
                android:textStyle="bold"
                android:textSize="19sp"/>

            <!-- MA DON -->

            <TextView
                android:id="@+id/txttenxe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Xe: Mayback"
                android:textColor="#666666"
                android:textSize="15sp" />

            <!-- BIEN SO -->

            <TextView
                android:id="@+id/txtBienSo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Biển số: 36A-99999"
                android:textColor="#666666"
                android:textSize="15sp"/>

            <!-- GIA -->

            <TextView
                android:id="@+id/txtGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="1.500.000 VNĐ/ngày"
                android:textColor="#E91E63"
                android:textStyle="bold"
                android:textSize="16sp"/>

        </LinearLayout>

    </LinearLayout>


    <!-- ===================== TONG TIEN ===================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp">

        <!-- TINH TRANG -->

        <TextView
            android:id="@+id/txtTinhTrang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa duyệt"
            android:textColor="#FF9800"
            android:textStyle="bold"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/txtThanhToan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa thanh toán"
            android:layout_marginLeft="10dp"
            android:textColor="#FF0000"
            android:textStyle="bold"
            android:textSize="15sp"/>

        <!-- TONG TIEN -->

        <TextView
            android:id="@+id/txtThanhTien"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="4.500.000 VNĐ"
            android:textColor="#F44336"
            android:textStyle="bold"
            android:textSize="19sp"/>

    </LinearLayout>


    <!-- ===================== BUTTON ===================== -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="14dp"/>

</LinearLayout>