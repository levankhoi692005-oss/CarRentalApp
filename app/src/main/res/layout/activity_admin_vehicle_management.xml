<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE"
    tools:context=".admin.AdminVehicleManagement">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnquaylaidangnhap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Quay lại"
                android:textColor="#1565C0"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="QUẢN LÝ XE"
                android:textAlignment="center"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- CARD FORM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin xe"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#222222"
                    android:layout_marginBottom="16dp"/>

                <!-- INPUT -->
                <EditText
                    android:id="@+id/edittenxe"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Tên xe"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/editbienso"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Biển số"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/editdongia"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Đơn giá"
                    android:inputType="number"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/editmota"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Mô tả xe..."
                    android:gravity="top"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginBottom="16dp"/>

                <!-- IMAGE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/img1"
                        android:layout_width="120dp"
                        android:layout_height="90dp"
                        android:background="#EAEAEA"
                        android:scaleType="centerCrop"/>

                    <ImageView
                        android:id="@+id/img2"
                        android:layout_width="120dp"
                        android:layout_height="90dp"
                        android:layout_marginStart="12dp"
                        android:background="#EAEAEA"
                        android:scaleType="centerCrop"/>
                </LinearLayout>

                <!-- BUTTON CHỌN ẢNH -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btnChonAnh1"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="Ảnh 1"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#5E35B1"/>

                    <Button
                        android:id="@+id/btnChonAnh2"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="Ảnh 2"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#3949AB"/>
                </LinearLayout>

                <!-- ACTION BUTTON -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <Button
                        android:id="@+id/btnthem"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="Thêm"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#1976D2"/>

                    <Button
                        android:id="@+id/btnxoa"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Xóa"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#E53935"/>

                    <Button
                        android:id="@+id/btnsua"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Sửa"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#43A047"/>

                    <Button
                        android:id="@+id/btnchuyen"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Chuyển"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#FB8C00"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- TITLE LIST -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Danh sách xe"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="10dp"/>

        <!-- RECYCLER VIEW -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclereditxe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>