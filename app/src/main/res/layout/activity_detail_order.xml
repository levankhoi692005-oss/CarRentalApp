<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"

    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0ECEC"
    tools:context=".ui.DetailOrder">

    <LinearLayout
        android:id="@+id/linearLayout3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="40dp"
        android:padding="16dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"

        android:fitsSystemWindows="true"
        tools:ignore="MissingConstraints">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle"
                android:padding="10dp"
                android:src="@drawable/leave" />

            <TextView
                android:id="@+id/thongtin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thông tin đơn MD01"
                android:textAlignment="center"
                android:textColor="#111"
                android:textSize="28sp"
                android:textStyle="bold" />


        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="1dp"
            tools:ignore="MissingConstraints">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:background="@drawable/thongtin_circle">
<!--                Ten cy, dia chi cong ty, email lien he cua cty -->

                    <TextView
                        android:id="@+id/txt1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:background="#4CC81E"
                        android:text="Thông tin công ty" />

                    <TextView
                        android:id="@+id/txttency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:text=" Công ty CP thuê xe MMT01" />

                    <TextView
                        android:id="@+id/txtdiachi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Địa chỉ: Số 29,xã Hoài đức, TP Hà nội" />


                    <TextView
                        android:id="@+id/txtemail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Email: ctymmt01@gmail.com" />

                    <TextView
                        android:id="@+id/txtwebsite"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Website: https://ctymmt01.com" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="5dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/thongtin_circle">

                    <TextView
                        android:id="@+id/txt2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:background="#4CC81E"
                        android:text="Chi tiết đơn hàng" />

                    <TextView
                        android:id="@+id/txtmadon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="5dp"
                        android:layout_marginBottom="10dp"
                        android:text="Mã đơn: MD11" />

                    <TextView
                        android:id="@+id/txtkhach"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp"
                        android:text="Thông tin khách hàng" />

                    <TextView
                        android:id="@+id/txttenkh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Họ và tên: Lê văn khởi" />


                    <TextView
                        android:id="@+id/txtsdtkh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Số điện thoại: 09883283" />

                    <TextView
                        android:id="@+id/txtdiachikh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Địa chỉ: nhà 12, xã ABC , Tỉnh Hưng yên" />

                    <TextView
                        android:id="@+id/txtdon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="10dp"
                        android:layout_marginTop="10dp"
                        android:text="Thông tin đơn hàng" />

                    <TextView
                        android:id="@+id/tenxe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:text="Maybach s200" />
                    <TextView
                        android:id="@+id/hangxe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Hãng xe: Mercedes" />
                    <TextView
                        android:id="@+id/bienso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Biển số: 36G1-000000" />
                    <TextView
                        android:id="@+id/namsx"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Năm sản xuất: 2001" />

                    <TextView
                        android:id="@+id/mauxe"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Màu: Đen" />
                    <TextView
                        android:id="@+id/hopso"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Hộp số: Tự động" />
                    <TextView
                        android:id="@+id/gia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Giá: 1000000/ngày" />

                    <TextView
                        android:id="@+id/ngaydangky"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:layout_marginTop="10dp"
                        android:text="Ngày đăng ký: 2026-08-08" />

                    <TextView
                        android:id="@+id/ngaylay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Ngày Lấy: 2026-08-08" />

                    <TextView
                        android:id="@+id/songaythue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Số ngày thuê: 3 ngày" />

                    <TextView
                        android:id="@+id/diachilay"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Địa chỉ nhận: nhà 12, xã ABC , Tỉnh Hưng yên" />


                    <TextView
                        android:id="@+id/nguoigiao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Người giao xe: Phùng Văn Dương" />

                    <TextView
                        android:id="@+id/songuoigiao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Số điện thoại:097861523" />

                    <TextView
                        android:id="@+id/txtghichu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:text="Ghi chú: " />


                    <TextView
                        android:id="@+id/tongtien"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:layout_marginTop="10dp"
                        android:textColor="#FA0000"
                        android:text="Tổng tiền: 90000 VND" />



                    <TextView
                        android:id="@+id/loaithanhtoan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:layout_marginTop="5dp"
                        android:textColor="#FA0000"
                        android:text="Phương thức: chuyển khoản" />

                    <TextView
                        android:id="@+id/tinhtrang"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="17sp"
                        android:layout_marginTop="5dp"
                        android:textColor="#FA0000"
                        android:text="Tình trạng: Chưa thanh toán" />

                    <TextView
                        android:id="@+id/thanhtoan"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:layout_marginTop="5dp"
                        android:textColor="#FFFFFF"
                        android:gravity="center"
                        android:layout_gravity="center_horizontal"
                        android:background="#6CD51A"
                        android:textStyle="bold"
                        android:text="Thanh toán" />



                </LinearLayout>


            </LinearLayout>

        </ScrollView>

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>