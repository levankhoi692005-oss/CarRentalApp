<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="match_parent">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FE">







    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:padding="16dp">



        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="10dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/leave"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thuê xe"
                android:textAlignment="center"
                android:textColor="#111"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- XE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imgXe"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:scaleType="centerCrop"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtTenXe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mercedes"
                        android:textColor="#111"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/txtBienSo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30A-99999"
                        android:textColor="#777"
                        android:textSize="15sp"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/txtGia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2.000.000đ/ngày"
                        android:textColor="#1565C0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- FORM -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            android:backgroundTint="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin khách hàng"
                    android:textColor="#111"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <!-- NGÀY GIỜ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="#EEF4FF"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngày đăng ký"
                            android:textColor="#666"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/txtNgayDangKy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14/05/2026"
                            android:textColor="#111"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical"
                        android:background="#EEF4FF"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Giờ đăng ký"
                            android:textColor="#666"
                            android:textSize="13sp"/>

                        <TextView
                            android:id="@+id/txtGioDangKy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22:30"
                            android:textColor="#111"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                </LinearLayout>

                <EditText
                    android:id="@+id/edtHoTen"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Họ và tên"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"/>

                <EditText
                    android:id="@+id/edtSDT"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Số điện thoại"
                    android:inputType="phone"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginTop="12dp"/>
                <EditText
                    android:id="@+id/edtdiachikh"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Địa chỉ khách hàng"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"/>
                <EditText
                    android:id="@+id/edtdiachinhan"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Địa chỉ nhận xe"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"/>

                <EditText
                    android:id="@+id/edtNgayLay"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Ngày lấy xe"
                    android:focusable="false"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginTop="12dp"/>

                <EditText
                    android:id="@+id/edtSoNgay"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Số ngày thuê"
                    android:inputType="number"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginTop="12dp"/>

                <!-- TỔNG -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#EEF4FF"
                    android:padding="14dp"
                    android:layout_marginTop="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng tiền:"
                        android:textStyle="bold"
                        android:textSize="18sp"/>

                    <TextView
                        android:id="@+id/txtTongTien"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0đ"
                        android:textColor="#1565C0"
                        android:textStyle="bold"
                        android:textSize="20sp"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

                <!-- THANH TOÁN -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phương thức thanh toán"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="18dp"
                    android:layout_marginBottom="10dp"/>

                <RadioGroup
                    android:id="@+id/radioThanhToan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioChuyenKhoan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chuyển khoản"/>

                    <RadioButton
                        android:id="@+id/radioTienMat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tiền mặt"/>

                    <RadioButton
                        android:id="@+id/radioCaHai"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cả hai"/>

                </RadioGroup>

                <EditText
                    android:id="@+id/edtGhiChu"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Ghi chú thêm..."
                    android:gravity="top"
                    android:padding="14dp"
                    android:background="@drawable/edittext_bg"
                    android:layout_marginTop="16dp"/>

                <Button
                    android:id="@+id/btnThue"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:text="Xác nhận thuê xe"
                    android:textAllCaps="false"
                    android:textColor="#FFF"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="22dp"
                    android:backgroundTint="#1565C0"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="50dp"
        android:visibility="gone"
        android:background="#49C34F"
        android:layout_gravity="top|center_horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:elevation="10dp"
        >

        <TextView
            android:id="@+id/notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thuê xe thành công"
            android:textColor="#FFFFFF"
            />


    </LinearLayout>
</FrameLayout>