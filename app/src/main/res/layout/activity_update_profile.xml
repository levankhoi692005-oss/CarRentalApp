<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/anhnen">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="#FFFFFF"
                app:cardCornerRadius="30dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- TITLE -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cập nhật thông tin"
                        android:textStyle="bold"
                        android:textSize="28sp"
                        android:textColor="#183B56"
                        android:layout_gravity="center"
                        android:layout_marginBottom="30dp"/>

                    <!-- HỌ TÊN -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Họ và tên"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtName"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập họ tên"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giới tính"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <Spinner
                        android:id="@+id/edtgender"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập họ tên"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- EMAIL -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/editEmail"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập email"
                        android:inputType="textEmailAddress"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- PHONE -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập số điện thoại"
                        android:inputType="phone"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- NGÀY SINH -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày sinh"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtBirthday"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Chọn ngày sinh"
                        android:focusable="false"
                        android:clickable="true"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- CCCD -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CCCD"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtCCCD"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập CCCD"
                        android:inputType="number"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- GPLX -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số GPLX"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtGPLX"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Nhập số GPLX"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- HẠNG BẰNG -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hạng bằng lái"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <Spinner
                        android:id="@+id/spinnerLicense"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"/>

                    <!-- HẾT HẠN -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày hết hạn GPLX"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <EditText
                        android:id="@+id/edtExpire"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="18dp"
                        android:hint="Chọn ngày hết hạn"
                        android:focusable="false"
                        android:clickable="true"
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- ĐỊA CHỈ -->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Địa chỉ"
                        android:textStyle="bold"
                        android:textColor="#183B56"/>

                    <Spinner
                        android:id="@+id/spinnerProvince"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="10dp"/>

                    <Spinner
                        android:id="@+id/spinnerDistrict"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"/>

                    <Spinner
                        android:id="@+id/spinnerWard"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"/>

                    <EditText
                        android:id="@+id/edtDetailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:layout_marginTop="12dp"
                        android:hint="Số nhà, tên đường..."
                        android:paddingStart="18dp"
                        android:paddingEnd="18dp"
                        android:backgroundTint="#BFE6DF"/>

                    <!-- BUTTON -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        >
                        <Button
                            android:id="@+id/btnthoat"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            android:layout_marginTop="30dp"
                            android:text="  Thoát  "
                            android:textStyle="bold"
                            android:layout_marginRight="15dp"
                            android:layout_marginLeft="19dp"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#00A896"/>
                        <Button
                            android:id="@+id/btnConfirm"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            android:layout_marginTop="30dp"
                            android:text="  Cập nhật  "
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#00A896"/>



                    </LinearLayout>


                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="50dp"
        android:visibility="gone"
        android:background="#49C34F"
        android:layout_gravity="top|center_horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:elevation="10dp"
        >

        <TextView
            android:id="@+id/notification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thuê xe thành công"
            android:textColor="#FFFFFF"
            />


    </LinearLayout>

</FrameLayout>


