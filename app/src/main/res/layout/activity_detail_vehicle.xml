<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"

        android:fitsSystemWindows="true"
        tools:ignore="MissingConstraints"
        >

        <!-- HEADER -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="10dp"
                android:background="@drawable/bg_circle"
                android:src="@drawable/leave"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chi tiết xe"
                android:textAlignment="center"
                android:textColor="#111111"
                android:textSize="28sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- ẢNH 1 -->

        <ImageView
            android:id="@+id/img1"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"/>

        <!-- ẢNH 2 -->

        <ImageView
            android:id="@+id/img2"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="12dp"
            android:background="#DDDDDD"
            android:scaleType="centerCrop"/>

        <!-- CARD INFO -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#FFFFFF"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/txtTenXe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mercedes AMG G63"
                android:textColor="#000000"
                android:textSize="30sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Giá: 1.000.000 VNĐ"
                android:textColor="#4CAF50"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtBienSo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Biển số: 36G1-99999"
                android:textSize="17sp"/>



            <TextView
                android:id="@+id/txtMau"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Màu: Đen"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtSoGhe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Số ghế: 5"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtNhienLieu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Nhiên liệu: Xăng"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtHopSo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Hộp số: Tự động"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtCongSuat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Công suất: 577HP"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtNamSX"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Năm sản xuất: 2024"
                android:textSize="17sp"/>
            <TextView
                android:id="@+id/txtMoTa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Mô tả: Xe SUV hạng sang"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtCongTy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Công ty quản lý: MMT01 company"
                android:textColor="#E91E63"
                android:textSize="18sp"
                android:textStyle="bold"/>
            <TextView
                android:id="@+id/txtChuSoHuu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Chủ sở hữu: Nguyễn Văn A"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/txtDangKiem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Đăng kiểm đến năm: 2027"
                android:textSize="17sp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>